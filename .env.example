# Configuración del servidor
PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>
DB_URI=tu_mongodb_uri_aqui

# Autenticación (JWT)
JWT_SECRET_ACCESS=tu_clave_secreta_para_access_token
JWT_EXPIRES_IN=15m

# (Añade esta cuando implementemos el refresh)
JWT_SECRET_REFRESH=tu_clave_secreta_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d

# URL de slack
SLACK_WEBHOOK=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# API key Cloudinary
CLOUDINARY_CLOUD_NAME=tu_nombre_de_cloudinary
CLOUDINARY_API_KEY=tu_api_key_de_cloudinary
CLOUDINARY_API_SECRET=-tu_api_secret_key_de_cloudinary

# Email (Nodemailer) — usa Mailtrap sandbox para desarrollo/testing
# Mailtrap: sandbox.smtp.mailtrap.io  puerto: 2525
# Producción: cambia a tu proveedor SMTP real (Gmail, SendGrid, SES, etc.)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=tu_usuario_mailtrap
EMAIL_PASS=tu_password_mailtrap
EMAIL_FROM=BildyApp <no-reply@bildy.app>