@verificationCode = 367827

### ============================================================
### SECCIÓN 1: REGISTRO Y AUTENTICACIÓN (Puntos 1, 2, 3 de Rúbrica)
### ============================================================

### Prueba 1: Registro con éxito (201 Created)
# @name register
POST {{baseUrl}}/user/register
Content-Type: application/json

{
  "email": "guest_test@test.com",
  "password": "Bildy2026!",
  "extra_field": "Hacker intentando inyectar basura" 
}

### Prueba 2: Registro con errores (400 Bad Request)
# Password corta y email inválido
POST {{baseUrl}}/user/register
Content-Type: application/json

{
  "email": "no-es-email",
  "password": "123"
}

### Prueba 3: Registro Duplicado (409 Conflict)
POST {{baseUrl}}/user/register
Content-Type: application/json

{
  "email": "bildy_master@test.com",
  "password": "CualquierPassword123!"
}

### Prueba 4: Login Correcto (200 OK)
# @name login
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "email": "guest_test@test.com",
  "password": "Bildy2026!"
}

### Prueba 5: Login Fallido (401 Unauthorized)
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "email": "bildy_master@test.com",
  "password": "Password_Incorrecta"
}

### ============================================================
### SECCIÓN 2: VALIDACIÓN DE EMAIL (Punto 2 de Rúbrica)
### ============================================================

### Prueba 6: Validación - Código incorrecto (Intento 1)
PUT {{baseUrl}}/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{ "code": "000000" }

### Prueba 7: Validación - Código incorrecto (Intento 2)
PUT {{baseUrl}}/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{ "code": "111111" }

### Prueba 8: Validación - Código incorrecto (Intento 3)
PUT {{baseUrl}}/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{ "code": "222222" }

### Prueba 9: Validación - BLOQUEO (429 Too Many Requests)
# Al ser el 4º intento, debe dar error de intentos agotados
PUT {{baseUrl}}/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{ "code": "333333" }

### Prueba 10: Validación - Éxito (200 OK)
# Usa el código real de tu DB tras resetear los intentos en Atlas si es necesario
PUT {{baseUrl}}/user/validation
Authorization: Bearer {{token}}
Content-Type: application/json

{ "code": "{{verificationCode}}" }

### ============================================================
### SECCIÓN 3: ONBOARDING PERSONAL Y EMPRESA (Punto 4 de Rúbrica)
### ============================================================

### Prueba 11: Onboarding Personal - Éxito
# Probamos transformación de NIF a mayúsculas
PUT {{baseUrl}}/user/register
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Guest",
  "lastName": "Session",
  "nif": "12345698z"
}

### Prueba 12: Onboarding Empresa - Crear nueva (Admin/Owner)
PATCH {{baseUrl}}/user/company
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Test Corp S.L.",
  "cif": "B12345679",
  "address": {
    "street": "Calle de la Innovación",
    "number": "42",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### Prueba 13: Onboarding Empresa - Registro Autónomo (Bonus Union)
# El CIF será forzado por el controlador a tu NIF
PATCH {{baseUrl}}/user/company
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "isFreelance": true
}

### Prueba 14: Onboarding Empresa - Unirse a existente (Pasará a Guest)
# Requiere token de otro usuario verificado
PATCH {{baseUrl}}/user/company
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "isFreelance": false,
  "cif": "B12345678",
  "name": "Bildy Corp S.L.",
  "address": {
    "street": "Calle de la Innovación",
    "number": "42",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### ============================================================
### SECCIÓN 4: GESTIÓN DE PERFIL Y LOGO (Puntos 5, 6 de Rúbrica)
### ============================================================

### Prueba 15: Ver Perfil Completo (Populate + Virtuals)
GET {{baseUrl}}/user/me
Authorization: Bearer {{token}}

### Prueba 16: Subida de Logo (Multipart)
PATCH {{baseUrl}}/user/logo
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="logo"; filename="mologo.png"
Content-Type: image/png

< ./mologo.png
--boundary--

### Prueba 17: Acceso a Imagen Estática
# Cambia el nombre por el que devuelva la prueba anterior
GET http://localhost:3000/uploads/logo-69d55f98e5a1acfd289502db-1775591587143-720264085.png

### ============================================================
### SECCIÓN 5: ADMINISTRACIÓN E INVITACIONES (Punto 10 de Rúbrica)
### ============================================================

### Prueba 18: Invitar compañero (Admin)
POST {{baseUrl}}/user/invite
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "companero2@test.com",
  "name": "Juan2",
  "lastName": "Invitado2",
  "nif": "11223344K"
}

### Prueba 19: Error al invitar (Guest)
POST {{baseUrl}}/user/invite
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "error@test.com",
  "name": "Error",
  "lastName": "User",
  "nif": "00000000T"
}

### ============================================================
### SECCIÓN 6: SEGURIDAD Y BORRADO (Puntos 8, 9 de Rúbrica)
### ============================================================

### Prueba 20: Cambio de Password - Éxito
PUT {{baseUrl}}/user/password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "currentPassword": "Bildy2026!",
  "newPassword": "NuevaPassword2026!",
  "confirmPassword": "NuevaPassword2026!"
}

### Prueba 21: Cambio de Password - Error (Igual a la anterior)
PUT {{baseUrl}}/user/password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "currentPassword": "NuevaPassword2026!",
  "newPassword": "NuevaPassword2026!",
  "confirmPassword": "NuevaPassword2026!"
}

### Prueba 22: Inyección NoSQL (Sanitización)
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "email": { "$gt": "" },
  "password": "123"
}

### Prueba 23: Borrado Lógico (Soft Delete)
DELETE {{baseUrl}}/user?soft=true
Authorization: Bearer {{token}}

### Prueba 24: Ver Papelera (Solo Admin)
GET {{baseUrl}}/user/trash
Authorization: Bearer {{token}}

### Prueba 25: Borrado Físico (Hard Delete)
DELETE {{baseUrl}}/user?soft=false
Authorization: Bearer {{token}}

### ============================================================
### SECCIÓN 7: GESTIÓN DE SESIÓN (Punto 7 de Rúbrica)
### ============================================================

### Prueba 26: Refresh Token (Obtener nuevo Access)
POST {{baseUrl}}/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Prueba 27: Logout (Invalidar sesión)
POST {{baseUrl}}/user/logout
Authorization: Bearer {{token}}

### Prueba 28: Intento de Refresh tras Logout (Debe fallar)
POST {{baseUrl}}/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Prueba 29: Acceso denegado (Sin Token)
GET {{baseUrl}}/user/me

### Prueba 30: Acceso con Token Corrupto
GET {{baseUrl}}/user/me
Authorization: Bearer token-falso-123

### Prueba Nueva: Admin borra a Invitado
# Sustituye EL_ID_DEL_INVITADO por el que copiaste
DELETE http://localhost:3000/api/user/69d567c0a3d9fedb5fdc4541?soft=true
Authorization: Bearer {{token}}