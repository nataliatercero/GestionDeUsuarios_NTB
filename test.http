Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YmRlN2ZjNDFkMzJkM2VlMDkyNzI0YSIsImlhdCI6MTc3NDA1MzQ3OCwiZXhwIjoxNzc0MTM5ODc4fQ.PcuAGkPgM24ecQ6s2c61Yk5lFin96CsUAr7XTrcBLWI

### Prueba 4: Onboarding con éxito
# Nota: Enviamos NIF en minúsculas para probar el .transform() de Zod
PUT http://localhost:3000/api/user/register
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YmRlN2ZjNDFkMzJkM2VlMDkyNzI0YSIsImlhdCI6MTc3NDA1MzQ3OCwiZXhwIjoxNzc0MTM5ODc4fQ.PcuAGkPgM24ecQ6s2c61Yk5lFin96CsUAr7XTrcBLWI

{
  "name": "Natalia",
  "lastName": "Tercero",
  "nif": "12345678z",
  "phone": "600112233"
}

### Prueba 4.1: Onboarding con errores (Falta lastName)
PUT http://localhost:3000/api/user/register
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YmRlN2ZjNDFkMzJkM2VlMDkyNzI0YSIsImlhdCI6MTc3NDA1MzQ3OCwiZXhwIjoxNzc0MTM5ODc4fQ.PcuAGkPgM24ecQ6s2c61Yk5lFin96CsUAr7XTrcBLWI


{
  "name": "Natalia",
  "nif": "12345678Z"
}

